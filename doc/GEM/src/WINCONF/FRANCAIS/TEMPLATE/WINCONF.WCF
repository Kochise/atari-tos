<!- Configuration de WinConf 2 -><submenu name=winconf>	<label>Préférences WinConf</label>	<help>On rŖgle ici les préférences de WinConf (un programme de qualité).</help>	<entry name=language type=popup data=string value="english" range="francais;english">		<label>Language: </label>		<help>Choix de la langue pour l'interface graphique.</help>	</entry>	<entry name=open_at_boot type=checkbut>		<label>Fenłtre principale au démarrage</label>		<help>Sous systŖme monotāche, la fenłtre principale sera ouverte.</help>	</entry>	<entry name=bubble type=checkbut>		<label>Bulles d'aide temporisées</label>		<help>Les bulles d'aides sont activées automatiquement aprŖs un délai d'immobilité de la souris.</help>	</entry>	<entry name=backup type=checkbut>		<label>Copie de sécurité</label>		<help>Une version précédente sera générée avant la sauvegarde du fichier de configuration.</help>	</entry>	<entry name=comment type=checkbut>		<label>Préserver les commentaires</label>		<help>Les commentaires sont gardés en mémoire sinon, ils sont purgés.</help>	</entry>	<entry name=savepos type=checkbut>		<label>Sauver la position des fenłtres</label>		<help>La position des fenłtres sera sauvegardée puis restauré lors du prochain lancement du programme.</help>	</entry>	<submenu name=font>		<label>Apparence du texte</label>		<entry name=name type=fontsel value=System>			<label>Fonte:  </label>		</entry>		<entry name=size type=fedit data=integer value=13>			<label>Taille: </label>		</entry>		<entry name=interline type=fedit data=integer value=4>			<label>Écart entre chaque lignes: </label>		</entry>	</submenu>	<entry name=xywh type=hidden>		<label>Ne pas éditer ce champs ! </label>			</entry></submenu><!- WinConf utilise WinDom bien sur et WinEdit egalement -><require src="windom.wcf"><require src="winedit.wcf"><!- Fin de config ->