<!--   Configuration of WinDom   WinConf template file      by Dominique Bārāziat, all rigths reserved (c) 2001   last modification the 11/07/2001
      _syntax_      <TAG attribute="value"> texte </TAG>       _Description_of_possible_tags_      <SUBMENU>	Add a group of variable     possible attributes :   		NAME=name 			; group name		TYPE=hidden			; item to hide   </SUBMENU>      <ENTRY>		Add a variable      possible attributes   		NAME=name			; variable anme   		TYPE=popup, radiobut, checkbut, fedit,    			 fontsel, filesel, colorsel, pattsel   		DATA=string, float, integer, boolean, list   		RANGE="value 1:value 2:..." used by popup, radio buttons   		VALUE=<defaut value>   </ENTRY>   <HELP>Information on variable/group</HELP>   <LABEL>Label which appears in WinConf (instead of variable/group name).</LABEL>   <REQUIRE src="file"> 	; load a template file. --><SUBMENU NAME=windom TYPE=library>	<LABEL>Gestionnaire GEM</LABEL>	<HELP>Configuration de l'interface GEM WinDom</HELP>	<SUBMENU NAME=evnt TYPE=group>		<LABEL>źvānements</LABEL>		<HELP>Comportement des āvānements GEM</HELP>		<ENTRY NAME=keybd TYPE=radiobut VALUE="front" RANGE="front;mouse">			<LABEL>Clavier:     </LABEL>			<HELP>Comportement des āvānements clavier</HELP>		</ENTRY>		<ENTRY NAME=button TYPE=radiobut VALUE="mouse" RANGE="front;mouse">			<LABEL>Clic souris: </LABEL>			<HELP>Comportement des āvānements clic souris</HELP>		</ENTRY>	</SUBMENU>	<SUBMENU NAME=button>		<LABEL>Boutons standards</LABEL>		<HELP>Apparence des boutons autres que de sortie (couleur,fonte,taille)</HELP>		<ENTRY NAME=color TYPE=colorsel VALUE=1>			<LABEL>Couleur: </LABEL>			<HELP>Couleur du texte des boutons</HELP>		</ENTRY>		<ENTRY NAME=font TYPE=fontsel VALUE="system">			<LABEL>Fonte:   </LABEL>			<HELP>Fontes du texte des boutons</HELP>		</ENTRY>		<ENTRY NAME=size TYPE=fedit DATA=integer VALUE=10>			<LABEL>Taille:  </LABEL>			<HELP>Taille du texte des boutons</HELP>		</ENTRY>	</SUBMENU>	<SUBMENU NAME=exit>		<LABEL>Boutons de sortie</LABEL>		<HELP>Apparence des boutons de sortie (couleur,fonte,taille)</HELP>		<ENTRY NAME=color TYPE=colorsel DATA=integer VALUE=1>			<LABEL>Couleur: </LABEL>			<HELP>Couleur du texte des boutons de sortie</HELP>		</ENTRY>		<ENTRY NAME=font TYPE=fontsel DATA=string VALUE="Arial">			<LABEL>Fonte:   </LABEL>			<HELP>Fontes du texte des boutons de sortie</HELP>		</ENTRY>		<ENTRY NAME=size TYPE=fedit DATA=integer VALUE=10>			<LABEL>Taille:  </LABEL>			<HELP>Taille du texte des boutons sortie</HELP>		</ENTRY>	</SUBMENU>	<SUBMENU NAME=string>		<LABEL>Textes standards</LABEL>		<HELP>Apparence des textes autres que boutons (couleur,fonte,taille)</HELP>		<ENTRY NAME=color TYPE=colorsel DATA=integer VALUE=1>			<LABEL>Couleur: </LABEL>			<HELP>Couleur des textes</HELP>		</ENTRY>		<ENTRY NAME=font TYPE=fontsel DATA=string VALUE="Arial Bold">			<LABEL>Fonte:   </LABEL>			<HELP>Fontes des textes</HELP>		</ENTRY>		<ENTRY NAME=size TYPE=fedit DATA=integer VALUE=10>			<LABEL>Taille:  </LABEL>			<HELP>Taille des textes</HELP>		</ENTRY>	</SUBMENU>	<SUBMENU NAME=xlongedit>		<LABEL>Textes Ö lignes mutiples</LABEL>		<HELP>Apparence du texte Ö ligne mutliple (couleur,fonte,taille)</HELP>		<ENTRY NAME=color TYPE=colorsel DATA=integer VALUE=1>			<LABEL>Couleur: </LABEL>			<HELP>Couleur des textes</HELP>		</ENTRY>		<ENTRY NAME=font TYPE=fontsel DATA=string VALUE="Arial Italic">			<LABEL>Fonte:   </LABEL>			<HELP>Fontes des textes</HELP>		</ENTRY>		<ENTRY NAME=size TYPE=fedit DATA=integer VALUE=10>			<LABEL>Grande taille:  </LABEL>			<HELP>Taille des textes (grande fonte).</HELP>		</ENTRY>		<ENTRY NAME=smallsize TYPE=fedit DATA=integer VALUE=10>			<LABEL>Petite taille:  </LABEL>			<HELP>Taille des textes (petite fonte).</HELP>		</ENTRY>	</SUBMENU>	<SUBMENU NAME=xedit>		<LABEL>Champs de saisie ātendus</LABEL>		<HELP>Apparence des champs de saisie Ö longueur variable.</HELP>		<SUBMENU Name=label>			<LABEL>Intitulā</LABEL>			<HELP>Apparence des intitulās (texte Ö gauche) des champs de saisie Ö longueur variable.</HELP>			<ENTRY NAME=color TYPE=colorsel DATA=integer VALUE=1>				<LABEL>Couleur: </LABEL>				<HELP>Couleur du texte de l'intitulā.</HELP>			</ENTRY>			<ENTRY NAME=font TYPE=fontsel DATA=string VALUE="Arial">				<LABEL>Fonte:   </LABEL>				<HELP>Fontes du texte de l'intitulā.</HELP>			</ENTRY>			<ENTRY NAME=size TYPE=fedit DATA=integer VALUE=10>				<LABEL>Taille:  </LABEL>				<HELP>Taille du texte de l'intitulā.</HELP>			</ENTRY>		</SUBMENU>		<SUBMENU Name=text>			<LABEL>Zone de saisie</LABEL>			<HELP>Apparence du texte dans la zone de saisie.</HELP>			<ENTRY NAME=color TYPE=colorsel DATA=integer VALUE=1>				<LABEL>Couleur: </LABEL>				<HELP>Couleur du texte de la zone de saisie.</HELP>			</ENTRY>			<ENTRY NAME=font TYPE=fontsel DATA=string VALUE="Arial">				<LABEL>Fonte:   </LABEL>				<HELP>Fontes du texte de la zone de saisie.</HELP>			</ENTRY>			<ENTRY NAME=size TYPE=fedit DATA=integer VALUE=10>				<LABEL>Taille:  </LABEL>				<HELP>Taille du texte de la zone de saisie.</HELP>			</ENTRY>		</SUBMENU>	</SUBMENU>	<SUBMENU NAME=menu>		<LABEL>Menus des fenątres</LABEL>		<HELP>Apparence du texte des ālāments des menus (couleur,fonte,taille)</HELP>		<ENTRY NAME=color TYPE=colorsel DATA=integer VALUE=1>			<LABEL>Couleur: </LABEL>			<HELP>Couleur des textes</HELP>		</ENTRY>		<ENTRY NAME=font TYPE=fontsel DATA=string VALUE="Arial Italic">			<LABEL>Fonte:   </LABEL>			<HELP>Fontes des textes</HELP>		</ENTRY>		<ENTRY NAME=size TYPE=fedit DATA=integer VALUE=10>			<LABEL>Taille:  </LABEL>			<HELP>Taille des textes</HELP>		</ENTRY>		<ENTRY NAME=effect TYPE=popup RANGE="0;1;2;3;4;5" VALUE="3">			<LABEL>Nombre clignotement</LABEL>		</ENTRY>		<ENTRY NAME=scroll TYPE=checkbut>			<LABEL>activer scroller</LABEL>		</ENTRY>	</SUBMENU>	<SUBMENU NAME=popup>		<HELP>Apparence des menus popup (couleur,fonte,taille,cadre,fond)</HELP>		<LABEL>Menus popups</LABEL>		<ENTRY NAME=color TYPE=colorsel VALUE=0>			<LABEL>Couleur du fond:  </LABEL>		</ENTRY>		<ENTRY NAME=border TYPE=colorsel VALUE=2>			<LABEL>Couleur du bord:  </LABEL>		</ENTRY>		<ENTRY NAME=framec TYPE=colorsel VALUE=1>			<LABEL>Couleur du cadre: </LABEL>		</ENTRY>		<ENTRY NAME=pattern TYPE=pattsel VALUE=1>			<LABEL>Motif du fond:    </LABEL>		</ENTRY>		<ENTRY NAME=relief TYPE=checkbut VALUE=true>			<LABEL>effet de relief</LABEL>		</ENTRY>		<ENTRY NAME=window TYPE=checkbut VALUE=true>			<LABEL>mettre en fenątre</LABEL>			<HELP>Les menus popup en fenetre ne bloque pas l'AES</HELP>		</ENTRY>	</SUBMENU>	<SUBMENU NAME=window>
		<HELP>Paramātrage des fenątres</HELP>		<LABEL>Fenątres</LABEL>		<ENTRY NAME=effect TYPE=checkbut VALUE=true>			<LABEL>effets visuels</LABEL>		</ENTRY>		<ENTRY NAME=center TYPE=popup RANGE="screen;mouse;form;upleft;upright;dnleft;dnright" VALUE="screen">			<LABEL>Positionnement Ö l'ouverture: </LABEL>		</ENTRY>		<SUBMENU NAME=bg>			<LABEL>Style du fond</LABEL>			<ENTRY NAME=color TYPE=colorsel>				<LABEL>couleur: </LABEL>			</ENTRY>			<ENTRY NAME=style TYPE=pattsel>				<LABEL>motif:   </LABEL>			</ENTRY>			<ENTRY NAME=pattern TYPE=popup RANGE="1 (solid);2 (motif);3 (pattern)" VALUE="1 (solid)">				<LABEL>style:   </LABEL>			</ENTRY>		</SUBMENU>	</SUBMENU>	<SUBMENU NAME=mform>		<LABEL>Formulaires modaux</LABEL>		<ENTRY NAME=widget TYPE=bitfield DATA=hexa VALUE=0x9 RANGE="0x1 [nom];0x2 [];0x4 [];0x8 [ūmoverū];0x20 [];0x40 [];0x80 [];0x100 [Hor. slider];0x200 [];0x400 [];0x800 [Ver. slider];0x4000 []">			<LABEL>Attributs: </LABEL>			<HELP>Dāfini les attributs fenątre des formulaires modaux</HELP>		</ENTRY>	</SUBMENU>	<SUBMENU NAME=bubble>		<LABEL>Bulles d'aide</LABEL>		<HELP>Apparences des bulles d'aide BubbleGEM</HELP>		<entry name=font type=fontsel value="system">			<Label>Fonte: </label>		</entry>		<entry name=size type=fedit data=integer>			<Label>Taille: </label>		</entry>	</submenu>	<submenu NAME=fsel>		<label>Sālecteur de fichiers</label>		<entry name=fslx type=checkbut value=true><label>Utiliser l'extension FSLX</label></entry>		<entry name=path type=fedit data=string><label>Rāpertoires: </label></entry>		<entry name=mask type=fedit data=string><label>Masques:     </label></entry>	</submenu>	<SUBMENU NAME=iconify>		<LABEL>Iconification</LABEL>		<ENTRY NAME=geometry TYPE=fedit DATA=string></ENTRY>	</SUBMENU>	<SUBMENU NAME=shortcut>		<LABEL>Racourcis clavier</LABEL>		<ENTRY NAME=color TYPE=colorsel VALUE=1><LABEL>Couleur: </LABEL></ENTRY>	</SUBMENU>	<SUBMENU NAME=relief>		<LABEL>Effets reliefs</LABEL>		<HELP>Configure les effets de reliefs des objets</HELP>		<entry name=color type=colorsel value=13><label>16 couleurs: </label></entry>		<entry name=mono type=pattsel value=1>   <label>Monochrome:  </label></entry>	</SUBMENU>	<ENTRY NAME=version TYPE=checkbut VALUE=false>		<LABEL>Affichage version WinDom</LABEL>	</ENTRY>	<ENTRY NAME=debug TYPE=fedit DATA=string VALUE="">		<LABEL>Rāglage de la fonction debug()</LABEL>	</ENTRY></SUBMENU><!-- End Of File -->