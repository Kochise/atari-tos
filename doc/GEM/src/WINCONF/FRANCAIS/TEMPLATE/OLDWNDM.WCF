<!-- 	 Fichier descriptif des variables WinDom 	 dans sa version ant‚rieur a Avril 1998. Il existe encore	 quelques applications qui utilisent cette vieille version	 de windom. Pour celles-ci, creez un fichier WCF qui fait	 r‚f‚rence … ce fichier par la commande :	 	<require src="oldwndm.wcf"> --><ENTRY NAME=xtype_font_name TYPE=fontsel Value="system font">	<LABEL>Fonte texte types ‚tendus (WinDom):          </LABEL>	<HELP>piuet</HELP></ENTRY><ENTRY NAME=xtype_font_size TYPE=fedit DATA=integer VALUE=13>	<LABEL>Taille texte types ‚tendus (WinDom):         </LABEL></ENTRY><ENTRY NAME=xtype_exit_button_color TYPE=colorsel VALUE=1>	<LABEL>Couleur texte boutons EXIT ‚tendus (WinDom): </LABEL></ENTRY><ENTRY NAME=xtype_other_button_color TYPE=colorsel VALUE=1>	<LABEL>Couleur texte boutons ‚tendus (WinDom):      </LABEL></ENTRY><ENTRY NAME=xtype_string_color TYPE=colorsel VALUE=1>	<LABEL>Couleur texte objets ‚tendus (WinDom):       </LABEL></ENTRY><ENTRY NAME=xtype_shortcut_color TYPE=colorsel VALUE=1>	<LABEL>Couleur raccourci clavier (WinDom):          </LABEL></ENTRY><ENTRY NAME=mu_keybd_on_mouse TYPE=popup RANGE="true;false" VALUE="false">	<LABEL>Ev‚nement clavier sous la souris (WinDom):   </LABEL></ENTRY><ENTRY NAME=mu_button_on_mouse TYPE=popup RANGE="true;false" VALUE="false">	<LABEL>Ev‚nement souris sous la souris (WinDom):    </LABEL></ENTRY><ENTRY NAME=menu_effect TYPE=popup RANGE="0;1;2;3;4;5" VALUE="3">	<LABEL>Clignotement s‚lection menu (WinDom):        </LABEL></ENTRY><ENTRY NAME=icon_geometry TYPE=fedit DATA=string VALUE="72,72">	<LABEL>Taille fenˆtres icones (WinDom):             </LABEL></ENTRY><ENTRY NAME=windom_version TYPE=popup RANGE="true;false" VALUE="false">	<LABEL>Afficher version WinDom (WinDom):            </LABEL></ENTRY><ENTRY NAME=bubble_font TYPE=fedit DATA=string VALUE="Arial,10">	<LABEL>Fonte et taille bulles d'aide (WinDom):      </LABEL></ENTRY><!- END OF FILE ->