<!- Configuration de WinConf 2 -><submenu name=winconf>	<label>WinConf preferences</label>	<help>Specific configuration of WinConf</help>	<entry name=language type=popup data=string value="english" range="francais;english">		<label>Language: </label>		<help>Set the language.</help>	</entry>	<entry name=open_at_boot type=checkbut>		<label>Open main window at boot</label>		<help>Non multitasking OS : open the main window when WinConf is launched</help>	</entry>	<entry name=bubble type=checkbut>		<label>Bubble GEM with timer</label>		<help>Bubble help are automatically opened.</help>	</entry>	<entry name=backup type=checkbut>		<label>Create backup</label>		<help>Make a backup file of the previous version before saving.</help>	</entry>	<entry name=comment type=checkbut>		<label>Keep comments</label>		<help>Comments inside configuration file are keeped.</help>	</entry>	<entry name=savepos type=checkbut>		<label>Save window position</label>		<help>Window position (size and location) are saved and restored for the next time.</help>	</entry>	<submenu name=font>		<help>Set some visual aspects</help>		<label>Text style</label>		<entry name=name type=fontsel value=System>			<label>Font:  </label>			<help>Set the font of items in main window</help>		</entry>		<entry name=size type=fedit data=integer value=13>			<label>Size: </label>			<help>Set the size of items in main window</help>		</entry>		<entry name=interline type=fedit data=integer value=4>			<label>Offset between lines: </label>			<help>Set the width (in pixels) between each item in main window</help>		</entry>	</submenu>	<entry name=xywh type=hidden>	<label>Do not edit this variable!</label>	</entry></submenu><!- WinConf utilise WinDom bien sur et WinEdit egalement -><require src="windom.wcf"><require src="winedit.wcf"><!- Fin de config ->