<!-- 	 Fichier descriptif des variables WinDom 	 dans sa version ant‚rieur a Avril 1998. Il existe encore	 quelques applications qui utilisent cette vieille version	 de windom. Pour celles-ci, creez un fichier WCF qui fait	 r‚f‚rence … ce fichier par la commande :	 	<require src="oldwndm.wcf"> --><ENTRY NAME=xtype_font_name TYPE=fontsel Value="system font">	<LABEL>WinDom : String font of extended object :  </LABEL>	<HELP>Set the font of string.</HELP></ENTRY><ENTRY NAME=xtype_font_size TYPE=fedit DATA=integer VALUE=13>	<LABEL>WinDom : String size of extended object :  </LABEL></ENTRY><ENTRY NAME=xtype_string_color TYPE=colorsel VALUE=1>	<LABEL>WinDom : String color of extended object : </LABEL></ENTRY><ENTRY NAME=xtype_exit_button_color TYPE=colorsel VALUE=1>	<LABEL>WinDom : Exit button color :               </LABEL></ENTRY><ENTRY NAME=xtype_other_button_color TYPE=colorsel VALUE=1>	<LABEL>WinDom : Non exit button color :           </LABEL></ENTRY><ENTRY NAME=xtype_shortcut_color TYPE=colorsel VALUE=1>	<LABEL>WinDom : Keyboard Shortcut Color :         </LABEL>	<HELP>Set the color of shortcut keyboard in dialog boxes</HELP></ENTRY><ENTRY NAME=mu_keybd_on_mouse TYPE=popup RANGE="true;false" VALUE="false">	<LABEL>WinDom : Keyboard Event On Mouse :         </LABEL>	<HELP>Keyboard events can be sent to window pointed by mouse instead of top window</HELP></ENTRY><ENTRY NAME=mu_button_on_mouse TYPE=popup RANGE="true;false" VALUE="false">	<LABEL>WinDom : Mouse Button Event On Mouse :     </LABEL>	<HELP>Mouse button events can be sent to window pointed by mouse instead of top window</HELP></ENTRY><ENTRY NAME=menu_effect TYPE=popup RANGE="0;1;2;3;4;5" VALUE="3">	<LABEL>WinDom : Flashing Menu Selection Effect :  </LABEL>	<HELP>Controls the flashing effect when an item is selected in a window menu</HELP></ENTRY><ENTRY NAME=icon_geometry TYPE=fedit DATA=string VALUE="72,72">	<LABEL>WinDom : Iconfied Window Size :            </LABEL></ENTRY><ENTRY NAME=windom_version TYPE=popup RANGE="true;false" VALUE="false">	<LABEL>WinDom : Display WinDom Version :          </LABEL></ENTRY><ENTRY NAME=bubble_font TYPE=fedit DATA=string VALUE="Arial,10">	<LABEL>WinDom : BubbleGEM Font and Size :         </LABEL></ENTRY><!- END OF FILE ->