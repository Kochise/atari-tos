<!--   Configuration of WinDom   WinConf template file      by Dominique B‚r‚ziat, all rigths reserved (c) 2001   last modification the 11/07/2001      _syntax_      <TAG attribute="value"> texte </TAG>       _Description_of_possible_tags_      <SUBMENU>	Add a group of variable     possible attributes :   		NAME=name 			; group name		TYPE=hidden			; item to hide   </SUBMENU>      <ENTRY>		Add a variable      possible attributes   		NAME=name			; variable anme   		TYPE=popup, radiobut, checkbut, fedit,    			 fontsel, filesel, colorsel, pattsel   		DATA=string, float, integer, boolean, list   		RANGE="value 1:value 2:..." used by popup, radio buttons   		VALUE=<defaut value>   </ENTRY>   <HELP>Information on variable/group</HELP>   <LABEL>Label which appears in WinConf (instead of variable/group name).</LABEL>   <REQUIRE src="file"> 	; load a template file. --><SUBMENU NAME=windom TYPE=library>	<LABEL>GEM aspects</LABEL>	<HELP>Configuration of the GEM WinDom interface</HELP>	<SUBMENU NAME=evnt TYPE=group>		<LABEL>Events</LABEL>		<HELP>Behavior of some GEM events</HELP>		<ENTRY NAME=keybd TYPE=radiobut VALUE="front" RANGE="front;mouse">			<LABEL>Keyboard:     </LABEL>			<HELP>Keyboard events can be sent to top window or window pointed by mouse</HELP>		</ENTRY>		<ENTRY NAME=button TYPE=radiobut VALUE="mouse" RANGE="front;mouse">			<LABEL>Mouse Button: </LABEL>			<HELP>Mouse button events can be sent to top window or window pointed by mouse</HELP>		</ENTRY>	</SUBMENU>	<SUBMENU NAME=button>		<LABEL>Standard Buttons</LABEL>		<HELP>How standard buttons appear in dialog boxes</HELP>		<ENTRY NAME=color TYPE=colorsel VALUE=1>			<LABEL>Color: </LABEL>			<HELP>Set the color</HELP>		</ENTRY>		<ENTRY NAME=font TYPE=fontsel VALUE="system">			<LABEL>Font:  </LABEL>			<HELP>Set the font</HELP>		</ENTRY>		<ENTRY NAME=size TYPE=fedit DATA=integer VALUE=10>			<LABEL>Size:  </LABEL>			<HELP>Set the size</HELP>		</ENTRY>	</SUBMENU>	<SUBMENU NAME=exit>		<LABEL>Exit Buttons</LABEL>		<HELP>How exit buttons appear in dialog boxes</HELP>		<ENTRY NAME=color TYPE=colorsel VALUE=1>			<LABEL>Color: </LABEL>			<HELP>Set the color</HELP>		</ENTRY>		<ENTRY NAME=font TYPE=fontsel VALUE="system">			<LABEL>Font:  </LABEL>			<HELP>Set the font</HELP>		</ENTRY>		<ENTRY NAME=size TYPE=fedit DATA=integer VALUE=10>			<LABEL>Size:  </LABEL>			<HELP>Set the size</HELP>		</ENTRY>		</SUBMENU>	<SUBMENU NAME=string>		<LABEL>Standard Strings</LABEL>		<HELP>How standard strings appears in dialog boxes</HELP>		<ENTRY NAME=color TYPE=colorsel VALUE=1>			<LABEL>Color: </LABEL>			<HELP>Set the color</HELP>		</ENTRY>		<ENTRY NAME=font TYPE=fontsel VALUE="system">			<LABEL>Font:  </LABEL>			<HELP>Set the font</HELP>		</ENTRY>		<ENTRY NAME=size TYPE=fedit DATA=integer VALUE=10>			<LABEL>Size:  </LABEL>			<HELP>Set the size</HELP>		</ENTRY>	</SUBMENU>	<SUBMENU NAME=xlongedit>		<LABEL>Multiline BoxTexts</LABEL>		<HELP>How multiline box text appears in dialog boxes</HELP>		<ENTRY NAME=color TYPE=colorsel DATA=integer VALUE=1>			<LABEL>Color:       </LABEL>			<HELP>Set the color</HELP>		</ENTRY>		<ENTRY NAME=font TYPE=fontsel DATA=string VALUE="Arial Italic">			<LABEL>Font:        </LABEL>			<HELP>Set the font</HELP>		</ENTRY>		<ENTRY NAME=size TYPE=fedit DATA=integer VALUE=10>			<LABEL>Normal size: </LABEL>			<HELP>Set the size( when text is normal).</HELP>		</ENTRY>		<ENTRY NAME=smallsize TYPE=fedit DATA=integer VALUE=10>			<LABEL>Small size:  </LABEL>			<HELP>Set the size (when text is small).</HELP>		</ENTRY>	</SUBMENU>	<SUBMENU NAME=xedit>		<LABEL>Editable Fields</LABEL>		<HELP>Apparence des champs de saisie … longueur variable.</HELP>		<SUBMENU Name=label>			<LABEL>Intitul‚</LABEL>			<HELP>Apparence des intitul‚s (texte … gauche) des champs de saisie … longueur variable.</HELP>			<ENTRY NAME=color TYPE=colorsel DATA=integer VALUE=1>				<LABEL>Couleur: </LABEL>				<HELP>Couleur du texte de l'intitul‚.</HELP>			</ENTRY>			<ENTRY NAME=font TYPE=fontsel DATA=string VALUE="Arial">				<LABEL>Fonte:   </LABEL>				<HELP>Fontes du texte de l'intitul‚.</HELP>			</ENTRY>			<ENTRY NAME=size TYPE=fedit DATA=integer VALUE=10>				<LABEL>Taille:  </LABEL>				<HELP>Taille du texte de l'intitul‚.</HELP>			</ENTRY>		</SUBMENU>		<SUBMENU Name=text>			<LABEL>Zone de saisie</LABEL>			<HELP>Apparence du texte dans la zone de saisie.</HELP>			<ENTRY NAME=color TYPE=colorsel DATA=integer VALUE=1>				<LABEL>Couleur: </LABEL>				<HELP>Couleur du texte de la zone de saisie.</HELP>			</ENTRY>			<ENTRY NAME=font TYPE=fontsel DATA=string VALUE="Arial">				<LABEL>Fonte:   </LABEL>				<HELP>Fontes du texte de la zone de saisie.</HELP>			</ENTRY>			<ENTRY NAME=size TYPE=fedit DATA=integer VALUE=10>				<LABEL>Taille:  </LABEL>				<HELP>Taille du texte de la zone de saisie.</HELP>			</ENTRY>		</SUBMENU>	</SUBMENU>	<SUBMENU NAME=menu>		<LABEL>Menus</LABEL>		<HELP>How menus appear and react</HELP>		<ENTRY NAME=color TYPE=colorsel VALUE=1>			<LABEL>Color: </LABEL>			<HELP>Set the color</HELP>		</ENTRY>		<ENTRY NAME=font TYPE=fontsel VALUE="system">			<LABEL>Font:  </LABEL>			<HELP>Set the font</HELP>		</ENTRY>		<ENTRY NAME=size TYPE=fedit DATA=integer VALUE=10>			<LABEL>Size:  </LABEL>			<HELP>Set the size</HELP>		</ENTRY>		<ENTRY NAME=effect TYPE=popup RANGE="0;1;2;3;4;5" VALUE="3">			<LABEL>Flashing Menu Selection Effect: </LABEL>			<HELP>Controls the flashing effect when an item is selected in a window menu</HELP>		</ENTRY>		<ENTRY NAME=scroll TYPE=checkbut>			<LABEL>Menu Title Scroller: </LABEL>			<HELP>If set, a scroller appears in the window menu title</HELP>		</ENTRY>	</SUBMENU>	<SUBMENU NAME=popup>		<HELP>How menu popus appears</HELP>		<LABEL>Menu Popups</LABEL>		<ENTRY NAME=color TYPE=colorsel VALUE=0>			<LABEL>Background Color:   </LABEL>		</ENTRY>		<ENTRY NAME=border TYPE=colorsel VALUE=2>			<LABEL>Border Color:       </LABEL>		</ENTRY>		<ENTRY NAME=framec TYPE=colorsel VALUE=1>			<LABEL>Frame Color:        </LABEL>		</ENTRY>		<ENTRY NAME=pattern TYPE=pattsel VALUE=1>			<LABEL>Background Pattern: </LABEL>		</ENTRY>		<ENTRY NAME=relief TYPE=checkbut VALUE=true>			<LABEL>3D look: </LABEL>		</ENTRY>		<ENTRY NAME=window TYPE=checkbut VALUE=true>			<LABEL>Popup In Window: </LABEL>			<HELP>Popup are handled in GEM window and don't bloc AES</HELP>		</ENTRY>	</SUBMENU>	<SUBMENU NAME=window>		<HELP>How standard windows appear and react</HELP>		<LABEL>Windows</LABEL>		<ENTRY NAME=effect TYPE=checkbut VALUE=true>			<LABEL>Visual Effects</LABEL>		</ENTRY>		<ENTRY NAME=center TYPE=popup RANGE="screen;mouse;form;upleft;upright;dnleft;dnright" VALUE="screen">			<LABEL>Opening Position: </LABEL>		</ENTRY>		<SUBMENU NAME=bg>			<LABEL>WorkSpace Style</LABEL>			<ENTRY NAME=color TYPE=colorsel>				<LABEL>Color:   </LABEL>			</ENTRY>			<ENTRY NAME=style TYPE=pattsel>				<LABEL>Pattern: </LABEL>			</ENTRY>			<ENTRY NAME=pattern TYPE=popup RANGE="1 (solid);2 (motif);3 (pattern)" VALUE="1 (solid)">				<LABEL>Style:   </LABEL>			</ENTRY>		</SUBMENU>	</SUBMENU>	<SUBMENU NAME=mform>		<LABEL>Modal Dialog Box</LABEL>		<ENTRY NAME=widget TYPE=bitfield DATA=hexa VALUE=0x9 RANGE="0x1 [nom];0x2 [];0x4 [];0x8 [đmoverđ];0x20 [];0x40 [];0x80 [];0x100 [Hor. slider];0x200 [];0x400 [];0x800 [Ver. slider];0x4000 []">			<LABEL>Attributs: </LABEL>			<HELP>Set the GEM attributes of modal dialog boxes</HELP>		</ENTRY>	</SUBMENU>	<SUBMENU NAME=bubble>		<LABEL>Bubble Help</LABEL>		<HELP>How bubble help (handle by BubbleGEM) appears on screen</HELP>		<entry name=font type=fontsel value="system">			<Label>Font: </label>			<help>Set the font</help> 		</entry>		<entry name=size type=fedit data=integer>			<Label>Size: </label>			<help>Set the size</help>		</entry>	</submenu>	<submenu NAME=fsel>		<label>File Selector</label>		<entry name=fslx type=checkbut value=true><label>Utiliser l'extension FSLX</label></entry>		<entry name=path type=fedit data=string><label>R‚pertoires: </label></entry>		<entry name=mask type=fedit data=string><label>Masques:     </label></entry>	</submenu>	<SUBMENU NAME=iconify>		<LABEL>Iconification</LABEL>		<ENTRY NAME=geometry TYPE=fedit DATA=string></ENTRY>	</SUBMENU>	<SUBMENU NAME=shortcut>		<LABEL>Keyboard Shortcuts</LABEL>		<HELP>Set the color of shortcut keyboard in dialog boxes</HELP>		<ENTRY NAME=color TYPE=colorsel VALUE=1><LABEL>Couleur: </LABEL></ENTRY>	</SUBMENU>	<SUBMENU NAME=relief>		<LABEL>3D Effects</LABEL>		<HELP>Configure les effets de reliefs des objets</HELP>		<entry name=color type=colorsel value=13><label>16 couleurs: </label></entry>		<entry name=mono type=pattsel value=1>   <label>Monochrome:  </label></entry>	</SUBMENU>	<ENTRY NAME=version TYPE=checkbut VALUE=false>		<LABEL>Display WinDom Version</LABEL>	</ENTRY>	<ENTRY NAME=debug TYPE=fedit DATA=string VALUE="">		<LABEL>Parameters of function debug()</LABEL>	</ENTRY></SUBMENU><!-- End Of File -->