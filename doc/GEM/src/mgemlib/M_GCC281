#
# makefile for mgemlib 
# gcc 2.81 version (32 bits)
#

# note:
# CC_GCC281 must point to your gcc.ttp program
# AR_GCC281 must point to your  ar.ttp program

CC     = $(CC_GCC281)
AR     = $(AR_GCC281)
CFLAGS = -O2 -Wall -m68000 -Iinclude

include m_files

.SUFFIXES:
.SUFFIXES: .c .s .o

.c.o:
	$(CC) $(CFLAGS) -c $*.c -o $*.o

.s.o:
	$(CC) $(CFLAGS) -c $*.s -o $*.o

TARGET = $(LIB_GCC281)

$(TARGET): $(OBJ) $(GC_OBJ)
	$(RM) $@
	$(AR) cs $@ $^
