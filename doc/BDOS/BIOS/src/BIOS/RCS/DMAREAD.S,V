SPSCSIMR	equ	bSPSCSI+2	; mode register
SPSCSITCR	equ	bSPSCSI+3	; target command register
SPSCSICR	equ	bSPSCSI+4	; current SCSI control register
SPSCSIDSR	equ	bSPSCSI+5	; DMA status register
