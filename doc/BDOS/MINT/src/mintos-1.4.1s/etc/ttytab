ttyp8	none			network	off 		# u:\pipe\ttyp.p8
ttyp9	none			network	off 		# u:\pipe\ttyp.p9
ttypa	none			network	off 		# u:\pipe\ttyp.pa
ttypb	none			network	off 		# u:\pipe\ttyp.pb
ttypc	none			network	off 		# u:\pipe\ttyp.pc
